{
  "entities": {
    "users": {
      "title": "User",
      "description": "A user in the Exona platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "places": {
      "title": "Place",
      "description": "A school, business, or community space created by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["School", "Business", "Community", "Personal", "Other"] },
        "description": { "type": "string" },
        "logo": { "type": "string" },
        "creatorUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isOfficial": { "type": "boolean" }
      },
      "required": ["name", "category", "creatorUid", "timestamp"]
    },
    "studentRecords": {
      "title": "Student Record",
      "description": "A record for a student (fees, books, etc.) with privacy settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentName": { "type": "string", "description": "Name of the student." },
        "category": { "type": "string" },
        "paid": { "type": "number" },
        "balance": { "type": "number" },
        "type": { "type": "string", "enum": ["general", "books", "uniforms", "services", "products"] },
        "visibility": { "type": "string", "enum": ["public", "private", "shared"] },
        "sharedWith": { "type": "array", "items": { "type": "string" } },
        "schoolId": { "type": "string" },
        "creatorUid": { "type": "string" },
        "addedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "category", "visibility", "creatorUid", "timestamp"]
    },
    "teacherAttendance": {
      "title": "Teacher Attendance",
      "description": "A record of teacher attendance for a specific school.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherName": { "type": "string" },
        "schoolId": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "date": { "type": "string", "format": "date" },
        "addedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherName", "schoolId", "status", "date", "timestamp"]
    },
    "finance": {
      "title": "School Finance",
      "description": "Financial details for a school or institution.",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "placeId": { "type": "string" },
        "institutionBalance": { "type": "number" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountName": { "type": "string" }
      },
      "required": ["institutionBalance"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "users", "description": "User profiles" },
    "/places/{placeId}": { "schema": "places", "description": "User-created places/institutions" },
    "/schools/{schoolId}": { "schema": "places", "description": "User-created schools" },
    "/studentRecords/{recordId}": { "schema": "studentRecords", "description": "Student records linked to schools" },
    "/teacherAttendance/{attendanceId}": { "schema": "teacherAttendance", "description": "Teacher attendance logs" },
    "/finance/{institutionId}": { "schema": "finance", "description": "Financial data for institutions" }
  }
}
