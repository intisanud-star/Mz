{
  "entities": {
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["message", "follower_request", "system", "like", "comment"] },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" },
        "link": { "type": "string" },
        "senderUid": { "type": "string" },
        "targetId": { "type": "string" }
      },
      "required": ["type", "title", "text", "isRead"]
    },
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "schoolId": { "type": "string" },
        "following": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "displayName"]
    },
    "School": {
      "title": "School",
      "description": "Educational institution",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string", "format": "uri" },
        "type": { "type": "string", "enum": ["school"] },
        "creatorUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "educationalLevels": { "type": "array", "items": { "type": "string" } },
        "administrativeViewers": { "type": "array", "items": { "type": "string" } },
        "followers": { "type": "array", "items": { "type": "string" } },
        "pendingFollowers": { "type": "array", "items": { "type": "string" } },
        "replyPermission": { "type": "string", "enum": ["everyone", "followers", "none"], "description": "Who can reply to posts" }
      },
      "required": ["id", "name", "creatorUid"]
    },
    "Place": {
      "title": "Place",
      "description": "General institution or business",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["place"] },
        "category": { "type": "string", "enum": ["School", "Business", "Community", "Personal", "Other"] },
        "logo": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "creatorUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isOfficial": { "type": "boolean" },
        "administrativeViewers": { "type": "array", "items": { "type": "string" } },
        "followers": { "type": "array", "items": { "type": "string" } },
        "pendingFollowers": { "type": "array", "items": { "type": "string" } },
        "replyPermission": { "type": "string", "enum": ["everyone", "followers", "none"], "description": "Who can reply to posts" }
      },
      "required": ["id", "name", "creatorUid"]
    },
    "Post": {
      "title": "Post",
      "description": "Feed post or announcement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string", "format": "uri" },
        "mediaUrls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "likes": { "type": "number" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "commentsCount": { "type": "number" },
        "reshares": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isOfficial": { "type": "boolean" },
        "schoolId": { "type": "string" }
      },
      "required": ["authorUid", "content", "timestamp"]
    },
    "StudentRecord": {
      "title": "StudentRecord",
      "description": "Student financial or academic record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentName": { "type": "string" },
        "category": { "type": "string" },
        "paid": { "type": "number" },
        "balance": { "type": "number" },
        "type": { "type": "string", "enum": ["general", "books", "uniforms", "services", "products"] },
        "visibility": { "type": "string", "enum": ["public", "private", "shared"] },
        "sharedWith": { "type": "array", "items": { "type": "string" } },
        "schoolId": { "type": "string" },
        "creatorUid": { "type": "string" },
        "addedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "schoolId", "creatorUid"]
    },
    "TeacherAttendance": {
      "title": "TeacherAttendance",
      "description": "Teacher attendance log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherName": { "type": "string" },
        "schoolId": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" }
      },
      "required": ["teacherName", "schoolId", "status", "date"]
    },
    "SchoolFinance": {
      "title": "SchoolFinance",
      "description": "Financial details of an institution",
      "type": "object",
      "properties": {
        "institutionBalance": { "type": "number" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountName": { "type": "string" }
      },
      "required": ["institutionBalance"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderUid": { "type": "string" },
        "receiverUid": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "chatId": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["voice", "image", "video"] },
        "isGroup": { "type": "boolean" },
        "status": { "type": "string" }
      },
      "required": ["senderUid", "participants", "timestamp", "chatId"]
    },
    "Call": {
      "title": "Call",
      "description": "Voice call signaling",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "callerUid": { "type": "string" },
        "receiverUid": { "type": "string" },
        "status": { "type": "string", "enum": ["ringing", "active", "ended", "rejected", "missed"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["audio", "video"] },
        "chatId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["callerUid", "receiverUid", "status", "timestamp", "type", "participants"]
    },
    "TypingStatus": {
      "title": "TypingStatus",
      "description": "Real-time typing indicator status",
      "type": "object",
      "properties": {
        "isTyping": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "chatId": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["isTyping", "updatedAt", "chatId", "uid"]
    },
    "Story": {
      "title": "Story",
      "description": "User or institution status story",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "mediaUrl": { "type": "string", "format": "uri" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "schoolId": { "type": "string" },
        "viewers": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["authorUid", "authorName", "mediaUrl", "mediaType", "timestamp", "expiresAt"]
    },
    "Settlement": {
      "title": "Settlement",
      "description": "Financial settlement request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["exona-bank", "other-bank"] },
        "bankName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" },
        "schoolId": { "type": "string" },
        "recipientId": { "type": "string" }
      },
      "required": ["amount", "type", "bankName", "status", "timestamp", "authorUid", "schoolId", "recipientId"]
    },
    "CloudFile": {
      "title": "CloudFile",
      "description": "User uploaded document or file",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "ownerUid": { "type": "string" },
        "schoolId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "enum": ["document", "image", "other"] }
      },
      "required": ["name", "url", "ownerUid", "timestamp"]
    },
    "ChatGroup": {
      "title": "ChatGroup",
      "description": "Group chat information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "creatorUid": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "admins": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creatorUid", "members", "timestamp"]
    },
    "BrainBattleParticipation": {
      "title": "BrainBattleParticipation",
      "description": "Game lead and quiz participation data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "uid": { "type": "string", "description": "Optional user UID if logged in" }
      },
      "required": ["name", "email", "phone", "address", "score", "timestamp"]
    },
    "KeyRequest": {
      "title": "KeyRequest",
      "description": "Request for institution portal access key",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "institutionName": { "type": "string" },
        "requesterUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["institutionId", "requesterUid", "status", "timestamp"]
    },
    "ExonWallet": {
      "title": "ExonWallet",
      "description": "Custom virtual currency wallet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "integer" },
        "excoin_balance": { "type": "integer" },
        "tier": { "type": "string" },
        "last_transaction": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "balance", "tier"]
    },
    "TransactionHistory": {
      "title": "TransactionHistory",
      "description": "Wallet transaction log",
      "type": "object",
      "properties": {
        "amount": { "type": "integer" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "currency": { "type": "string", "enum": ["stars", "excoins"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "type", "currency", "description", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/schools/{schoolId}": { "schema": "School", "description": "School institutions" },
    "/places/{placeId}": { "schema": "Place", "description": "Other institutions" },
    "/posts/{postId}": { "schema": "Post", "description": "Feed posts" },
    "/posts/{postId}/comments/{commentId}": { "schema": "object", "description": "Post comments" },
    "/studentRecords/{recordId}": { "schema": "StudentRecord", "description": "Student records" },
    "/teacherAttendance/{attendanceId}": { "schema": "TeacherAttendance", "description": "Teacher attendance" },
    "/finance/{schoolId}": { "schema": "SchoolFinance", "description": "Institution finance" },
    "/messages/{messageId}": { "schema": "Message", "description": "Chat messages" },
    "/typingStates/{stateId}": { "schema": "TypingStatus", "description": "User typing statuses" },
    "/users/{userId}/notifications/{notifId}": { "schema": "Notification", "description": "User notifications" },
    "/stories/{storyId}": { "schema": "Story", "description": "Status stories" },
    "/settlements/{settlementId}": { "schema": "Settlement", "description": "Financial settlement requests" },
    "/cloudFiles/{fileId}": { "schema": "CloudFile", "description": "User uploaded files" },
    "/chatGroups/{groupId}": { "schema": "ChatGroup", "description": "Group chat definitions" },
    "/calls/{callId}": { "schema": "Call", "description": "Voice call signaling documents" },
    "/brainBattleLeads/{leadId}": { "schema": "BrainBattleParticipation", "description": "Game leads and results" },
    "/keyRequests/{requestId}": { "schema": "KeyRequest", "description": "Access key requests" },
    "/wallets/{userId}": { "schema": "ExonWallet", "description": "User currency wallets" },
    "/wallets/{userId}/history/{txId}": { "schema": "TransactionHistory", "description": "Transaction logs" }
  }
}
