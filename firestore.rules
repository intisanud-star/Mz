rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "musstaphamusa@gmail.com" && request.auth.token.email_verified == true ||
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isSchoolManager(schoolId) {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/schools/$(schoolId)) && (
          get(/databases/$(database)/documents/schools/$(schoolId)).data.creatorUid == request.auth.uid ||
          (request.auth.token.email != null && request.auth.token.email_verified == true && get(/databases/$(database)/documents/schools/$(schoolId)).data.subAdmins != null && (request.auth.token.email in get(/databases/$(database)/documents/schools/$(schoolId)).data.subAdmins || request.auth.token.email.lower() in get(/databases/$(database)/documents/schools/$(schoolId)).data.subAdmins))
        )) ||
        (exists(/databases/$(database)/documents/places/$(schoolId)) && (
          get(/databases/$(database)/documents/places/$(schoolId)).data.creatorUid == request.auth.uid ||
          (request.auth.token.email != null && request.auth.token.email_verified == true && get(/databases/$(database)/documents/places/$(schoolId)).data.subAdmins != null && (request.auth.token.email in get(/databases/$(database)/documents/places/$(schoolId)).data.subAdmins || request.auth.token.email.lower() in get(/databases/$(database)/documents/places/$(schoolId)).data.subAdmins))
        ))
      );
    }

    function canReadRecord(recordData) {
      return recordData.visibility == 'public' ||
             recordData.creatorUid == request.auth.uid ||
             (recordData.visibility == 'shared' && request.auth.token.email != null && request.auth.token.email in recordData.sharedWith) ||
             isAdmin();
    }

    function isValidRecord(data) {
      return data.studentName is string && data.studentName.size() > 0 &&
             data.category is string &&
             data.visibility in ['public', 'private', 'shared'] &&
             data.paid is number &&
             data.balance is number &&
             data.schoolId is string;
    }

    function isValidPost(data) {
      return data.content is string && data.content.size() > 0 &&
             data.authorUid == request.auth.uid;
    }

    function isValidSchool(data) {
      return data.name is string && data.name.size() > 0 &&
             data.creatorUid == request.auth.uid;
    }

    function isValidAttendance(data) {
      return data.teacherName is string && data.teacherName.size() > 0 &&
             data.schoolId is string &&
             data.status in ['present', 'absent', 'late'] &&
             data.date is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /schools/{schoolId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && (isValidSchool(request.resource.data) || isAdmin());
      allow update: if isAuthenticated() && (
        isSchoolManager(schoolId) ||
        // User following (adding to pending)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingFollowers']) && 
         request.resource.data.pendingFollowers.hasAll(resource.data.pendingFollowers || []) &&
         request.auth.uid in request.resource.data.pendingFollowers) ||
        // User unfollowing (removing from followers or pending)
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['followers', 'pendingFollowers']) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'pendingFollowers']) &&
         !(request.auth.uid in (request.resource.data.followers || [])) &&
         !(request.auth.uid in (request.resource.data.pendingFollowers || [])))
      );
      allow delete: if isAdmin();
    }

    match /places/{placeId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && (isValidSchool(request.resource.data) || isAdmin());
      allow update: if isAuthenticated() && (
        isSchoolManager(placeId) ||
        // User following (adding to pending)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingFollowers']) && 
         request.resource.data.pendingFollowers.hasAll(resource.data.pendingFollowers || []) &&
         request.auth.uid in request.resource.data.pendingFollowers) ||
        // User unfollowing (removing from followers or pending)
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['followers', 'pendingFollowers']) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'pendingFollowers']) &&
         !(request.auth.uid in (request.resource.data.followers || [])) &&
         !(request.auth.uid in (request.resource.data.pendingFollowers || [])))
      );
      allow delete: if isAdmin();
    }

    match /teacherAttendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isSchoolManager(request.resource.data.schoolId) && isValidAttendance(request.resource.data);
      allow update, delete: if isAuthenticated() && (isSchoolManager(resource.data.schoolId) || isAdmin());
    }

    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    match /studentRecords/{recordId} {
      allow read: if isAuthenticated() && canReadRecord(resource.data);
      allow create: if isAuthenticated() && isSchoolManager(request.resource.data.schoolId) && isValidRecord(request.resource.data) && request.resource.data.creatorUid == request.auth.uid;
      allow update: if isAuthenticated() && (isSchoolManager(resource.data.schoolId) || resource.data.creatorUid == request.auth.uid || isAdmin()) && isValidRecord(request.resource.data) && request.resource.data.creatorUid == resource.data.creatorUid;
      allow delete: if isAuthenticated() && (isSchoolManager(resource.data.schoolId) || resource.data.creatorUid == request.auth.uid || isAdmin());
    }

    match /finance/{schoolId} {
      allow read: if isAuthenticated() && (resource.data.schoolId == schoolId || isAdmin() || isSchoolManager(schoolId));
      allow write: if isAdmin() || isSchoolManager(schoolId);
    }
  }
}
