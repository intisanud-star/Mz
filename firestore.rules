rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "musstaphamusa@gmail.com" && request.auth.token.email_verified == true ||
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function canReadRecord(recordData) {
      return recordData.visibility == 'public' ||
             recordData.creatorUid == request.auth.uid ||
             (recordData.visibility == 'shared' && request.auth.token.email in recordData.sharedWith) ||
             isAdmin();
    }

    function isValidRecord(data) {
      return data.studentName is string && data.studentName.size() > 0 &&
             data.category is string &&
             data.visibility in ['public', 'private', 'shared'] &&
             data.creatorUid == request.auth.uid &&
             data.paid is number &&
             data.balance is number;
    }

    function isValidPost(data) {
      return data.content is string && data.content.size() > 0 &&
             data.authorUid == request.auth.uid;
    }

    function isValidSchool(data) {
      return data.name is string && data.name.size() > 0 &&
             data.creatorUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /schools/{schoolId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && (isValidSchool(request.resource.data) || isAdmin());
      allow update: if isAuthenticated() && (resource.data.creatorUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    match /studentRecords/{recordId} {
      allow read: if isAuthenticated() && canReadRecord(resource.data);
      allow create: if isAuthenticated() && isValidRecord(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.creatorUid == request.auth.uid || isAdmin()) && isValidRecord(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.creatorUid == request.auth.uid || isAdmin());
    }

    match /finance/{schoolId} {
      allow read: if isAuthenticated() && (resource.data.schoolId == schoolId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
