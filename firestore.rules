rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "musstaphamusa@gmail.com" && request.auth.token.email_verified == true ||
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function canReadRecord(recordData) {
      return recordData.visibility == 'public' ||
             recordData.creatorUid == request.auth.uid ||
             (recordData.visibility == 'shared' && request.auth.token.email in recordData.sharedWith) ||
             isAdmin();
    }

    function isValidRecord(data) {
      return data.title is string && data.title.size() > 0 &&
             data.businessType is string &&
             data.visibility in ['public', 'private', 'shared'] &&
             data.creatorUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /records/{recordId} {
      allow read: if isAuthenticated() && canReadRecord(resource.data);
      allow create: if isAuthenticated() && isValidRecord(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.creatorUid == request.auth.uid || isAdmin()) && isValidRecord(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.creatorUid == request.auth.uid || isAdmin());
    }
  }
}
