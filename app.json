{
  "expo": {
    "name": "Exona",
    "slug": "exonapp-",
    "owner": "exon00001",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#ffffff",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.musstaphamusa.exona",
      "backgroundColor": "#ffffff",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Exona needs access to your microphone to allow you to record and send voice messages.",
        "NSCameraUsageDescription": "Exona needs access to your camera to allow you to take photos and videos for your stories and posts.",
        "NSLocationWhenInUseUsageDescription": "Exona needs access to your location to help you find nearby schools and places."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.musstaphamusa.exona",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "NOTIFICATIONS"
      ],
      "statusBar": {
        "backgroundColor": "#ffffff",
        "translucent": true,
        "barStyle": "dark-content"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7e031114-10b8-4592-a2bd-bf6908923725"
      }
    }
  }
}
