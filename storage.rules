rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /schools/{schoolId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null; // Simplified for demo, ideally check creatorUid
    }
    match /places/{placeId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null; // Simplified for demo
    }
    match /posts/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
